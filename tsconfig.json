{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true
  },
  "include": [
    "services/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
